{
  "manifest_version": 3,
  "name": "Yupoo Downloader",
  "version": "1.0.0",
  "description": "Baixe álbuns completos da Yupoo direto para o Google Drive com 1 clique.",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": [
    "https://*.yupoo.com/*", 
    "https://*.x.yupoo.com/*",
    "https://yupoodownloader.online/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.yupoo.com/*", 
        "https://*.x.yupoo.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://yupoodownloader.online/*"],
      "js": ["auth_bridge.js"],
      "run_at": "document_idle"
    }
  ]
}
