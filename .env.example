# ─── Copie para .env e preencha os valores ───────────────────────────────────
# NUNCA commite o .env no Git!

# ── Google OAuth ──────────────────────────────────────────────────────────────
# 1. Acesse: https://console.cloud.google.com
# 2. APIs e Serviços → Credenciais → Criar credenciais → ID do cliente OAuth
# 3. Tipo: Aplicativo da Web
# 4. URIs de redirecionamento: https://seudominio.com/api/auth/callback
GOOGLE_CLIENT_ID=seu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-seu-client-secret
GOOGLE_REDIRECT_URI=https://seudominio.com/api/auth/callback

# ── JWT (gere com: openssl rand -hex 32) ─────────────────────────────────────
JWT_SECRET=cole-aqui-uma-string-aleatoria-longa

# ── Stripe ────────────────────────────────────────────────────────────────────
# Chave secreta: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...

# Webhook secret: Stripe Dashboard → Webhooks → Adicionar endpoint
# URL do endpoint: https://seudominio.com/api/credits/webhook
# Eventos: checkout.session.completed
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs: Stripe Dashboard → Produtos → criar 4 produtos → copiar price_xxx
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_BUSINESS=price_xxx
STRIPE_PRICE_UNLIMITED=price_xxx

# ── URLs ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://seudominio.com
NEXT_PUBLIC_API_URL=https://seudominio.com/api
